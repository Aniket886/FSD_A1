{
  "name": "library-book-management-api",
  "version": "1.0.0",
  "description": "Express + MongoDB Library Book Management API with CI/CD, Docker, Jest, and Artillery load testing.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src tests --ext .js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage",
    "loadtest": "artillery run artillery/books-load-test.yml --output artillery/books-load-report.json"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "library",
    "books",
    "api"
  ],
  "author": "Team 1",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "artillery": "^2.0.31",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.3",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
